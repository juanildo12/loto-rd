generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Draw {
  id        Int      @id @default(autoincrement())
  date      DateTime
  gameType  String
  numbers   String   
  bonus     Int?
  bonus2    Int?
  prize     Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, gameType])
  @@index([date])
  @@index([gameType])
}
